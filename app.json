{
  "expo": {
    "name": "Tikiti Scanner",
    "slug": "tikiti-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#10b981"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tikiti.scanner",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to scan ticket QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10b981"
      },
      "package": "com.tikiti.scanner",
      "versionCode": 1,
      "permissions": ["CAMERA"]
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Tikiti Scanner to access your camera to scan ticket QR codes."
        }
      ]
    ]
  }
}
